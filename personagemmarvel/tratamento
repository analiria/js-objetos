function gerarEtiquetasEntrega(personagens) {
  personagens.forEach(p => {
    const endereco = p.endereco;
    const compl = endereco.complemento ? ` [${endereco.complemento}]` : '';
    const cep = endereco.cep ? ` - ${endereco.cep}` : '';
    
    console.log(`${p.nome} - ${endereco.rua}, ${endereco.numero}${compl}${cep}`);
  });
}