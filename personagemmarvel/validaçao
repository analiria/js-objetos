function encontrarTelefonesInvalidos(personagens) {
  const invalidos = [];

  personagens.forEach(p => {
    
    if (!p.telefones || p.telefones.length < 2) {
      invalidos.push(p.nome);
      return; 
    }

    const tel1 = p.telefones[0];
    const tel2 = p.telefones[1];

    const ddd = tel1.substring(0, 2);
    const restoNumero = tel1.substring(2);
    
    const telefoneEsperado = `${ddd}9${restoNumero}`;

    if (tel2 !== telefoneEsperado) {
      invalidos.push(p.nome);
    }
  });

  return invalidos;
}